# Copy this file to .env.local and fill in values from your Supabase project.
# Project Settings → API → URL and "anon public" key.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Required in Vercel (Production env): a long random string. Vercel Cron
# auto-sends this as `Authorization: Bearer ${CRON_SECRET}` to /api/health.
# Locally you can leave it unset (the endpoint will 401 either way).
CRON_SECRET=anything-you-pick
